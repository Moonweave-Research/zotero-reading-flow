{
  "manifest_version": 2,
  "name": "Zotero Reading Flow",
  "version": "1.0.0",
  "description": "Progress tracking and semantic colors for Zotero 9.",
  "author": "Reading Flow Team",
  "applications": {
    "zotero": {
      "id": "readingflow@example.com",
      "strict_min_version": "9.0",
      "strict_max_version": "9.0.*"
    }
  },
  "options_ui": {
    "page": "prefs.html",
    "browser_style": true
  },
  "icons": {
    "48": "icon.png",
    "96": "icon.png"
  }
}
